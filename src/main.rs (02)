#[derive(Clone, Debug, PartialEq)]
enum LocalOrderStatus {
    Placing,
    Open,
    PartiallyFilled { filled: String },
    FullyFilled,
    Canceled,
    Failed(String),
}

#[derive(Clone, Debug)]
struct TrackedOrder {
    id: String,
    side: String,
    token: String,
    price: String,
    size: String,
    status: LocalOrderStatus,
    size_matched: String,
    inline_sell_price: String,
    inline_sell_size: String,
}

#[derive(Clone, Debug)]
struct WindowGroup {
    timestamp_5m: u64,
    slug: String,
    is_expanded: bool,
    orders: Vec<TrackedOrder>,
}

#[derive(Clone, Debug)]
struct ToastNotification {
    message: String,
    kind: NotificationKind,
    expires_at: Instant,
}

/// Represents the type of notification to display in the GUI
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum NotificationKind {
    Error,   // tracing::Level::ERROR
    Warning, // tracing::Level::WARN
    Info,    // tracing::Level::INFO
    Debug,   // tracing::Level::DEBUG
    Trace,   // tracing::Level::TRACE
    Success, // custom success notifications
}

impl NotificationKind {
    /// Convert from a tracing level
    pub fn from_tracing_level(level: tracing::Level) -> Self {
        match level {
            tracing::Level::ERROR => NotificationKind::Error,
            tracing::Level::WARN => NotificationKind::Warning,
            tracing::Level::INFO => NotificationKind::Info,
            tracing::Level::DEBUG => NotificationKind::Debug,
            tracing::Level::TRACE => NotificationKind::Trace,
        }
    }
}

