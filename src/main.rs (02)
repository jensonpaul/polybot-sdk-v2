// ==========================================
// Tracing timer
// ==========================================

struct Timer {
    label: String,
    start: Instant,
}

impl Timer {
    fn start(label: &str) -> Self {
        Timer {
            label: label.to_string(),
            start: Instant::now(),
        }
    }

    fn done(&self) {
        let elapsed = self.start.elapsed();
        info!("Step '{}' completed in {:?}", self.label, elapsed);
    }
}

macro_rules! timed {
    ($label:expr, $block:block) => {{
        let timer = Timer::start($label);
        let result = { $block };
        timer.done();
        result
    }};
}

