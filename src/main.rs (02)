        let orders_to_poll = Arc::new(Mutex::new(Vec::<(u64, String)>::new()));
        
        // -------------------------------------------------------------
        // TASK 1: Isolated Heartbeat Polling Loop (Runs in its own track)
        // -------------------------------------------------------------
