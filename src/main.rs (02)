        let poll_tx = self.update_tx.clone();
        let poll_ctx = self.ctx.clone();
        
        tokio::spawn(async move {
            let mut interval = tokio::time::interval(Duration::from_secs(4));
            loop {
                interval.tick().await;
                
                // Snapshot the current list of orders inside the lock context safely
                let active_tracked_orders: Vec<(u64, String)> = {
                    match poll_orders.lock() {
                        Ok(lock) => lock.clone(),
                        Err(_) => continue, // Avoid panic if poisoned
                    }
                };

                if active_tracked_orders.is_empty() {
                    continue;
                }

                let mut active_removals = Vec::new();

                // Poll order statuses concurrently or sequentially without blocking incoming user commands
                for (window_ts, order_id) in active_tracked_orders {
                    if let Ok(res) = get_order_status(&order_id).await {
                        let status_str = res["details"]["status"].as_str().unwrap_or("OPEN");
                        let matched = res["details"]["matchedSize"].as_str().unwrap_or("0").to_string();
                        
                        let target_status = match status_str {
                            "FILLED" => {
                                active_removals.push(order_id.clone());
                                LocalOrderStatus::FullyFilled
                            }
                            _ => LocalOrderStatus::PartiallyFilled { filled: matched.clone() }
                        };
                        
                        let _ = poll_tx.send(WorkerUpdate::OrderUpdated {
                            window_ts,
                            order_id: order_id.clone(),
                            status: target_status,
                            matched
                        }).await;
                    }
                }

                // If any orders are fully filled, remove them from tracking list
                if !active_removals.is_empty() {
                    if let Ok(mut lock) = poll_orders.lock() {
                        lock.retain(|(_, id)| !active_removals.contains(id));
                    }
                }
                
                poll_ctx.request_repaint();
            }
        });

        // -------------------------------------------------------------
        // TASK 2: High-Speed UI Command Dispatcher Loop
        // -------------------------------------------------------------
        // By being at the root base level of the function, this loop starts instantly
        // right after Task 1 is handed off to the tokio executor runtime.
        tracing::info!("PolymarketWorker: Listening for UI Commands...");

        while let Some(cmd) = self.cmd_rx.recv().await {
            let update_tx = self.update_tx.clone();
            let ctx = self.ctx.clone();
            let cmd_orders_list = Arc::clone(&orders_to_poll);

            // Match each command and immediately spawn it into an independent network thread
            match cmd {
                UiCommand::PlaceLimit { side, token, price, size, window_ts } => {
                    tracing::info!("Worker caught PlaceLimit command!");
                    tokio::spawn(async move {
                        let current_anchor = initiate_stamp_5m();
                        let slug = build_slug_for_timestamp(current_anchor);
                        let req = OrderLimitRequest { 
                            side: side.clone(), 
                            token: token.clone(), 
                            price: price.clone(), 
                            size: size.clone() 
                        };
                        
                        match place_order_limit(&req, &slug).await {
                            Ok(res) => {
                                let order_id = res["response"]["orderID"].as_str().unwrap_or("MOCK_ID").to_string();
                                let new_order = TrackedOrder {
                                    id: order_id.clone(), side, token, price, size,
                                    status: LocalOrderStatus::Open, size_matched: "0".to_string(),
                                    inline_sell_price: "0.50".to_string(), inline_sell_size: "0".to_string(),
                                };
                                
                                // Register order inside shared polling stack safely
                                {
                                    let mut lock = cmd_orders_list.lock().unwrap();
                                    lock.push((window_ts, order_id.clone()));
                                }

                                let _ = update_tx.send(WorkerUpdate::OrderAdded { window_ts, order: new_order }).await;
                                let _ = update_tx.send(WorkerUpdate::Notify { message: "Limit Order Placed!".into(), kind: NotificationKind::Success }).await;
                            }
                            Err(e) => {
                                let _ = update_tx.send(WorkerUpdate::Notify { message: format!("Limit Failed: {}", e), kind: NotificationKind::Error }).await;
                            }
                        }
                        ctx.request_repaint();
                    });
                }

                UiCommand::PlaceMarket { side, token, usdc, shares, order_type, window_ts } => {
                    tokio::spawn(async move {
                        let current_anchor = initiate_stamp_5m();
                        let slug = build_slug_for_timestamp(current_anchor);
                        let req = OrderMarketRequest { side: side.clone(), token: token.clone(), usdc, shares, order_type };
                        
                        match place_order_market(&req, &slug).await {
                            Ok(res) => {
                                let order_id = res["response"]["orderID"].as_str().unwrap_or("MOCK_MARKET_ID").to_string();
                                let new_order = TrackedOrder {
                                    id: order_id.clone(), side, token, price: "Market".into(), size: "Market".into(),
                                    status: LocalOrderStatus::FullyFilled, size_matched: "Full".to_string(),
                                    inline_sell_price: "0.50".to_string(), inline_sell_size: "0".to_string(),
                                };
                                let _ = update_tx.send(WorkerUpdate::OrderAdded { window_ts, order: new_order }).await;
                                let _ = update_tx.send(WorkerUpdate::Notify { message: "Market Order Filled!".into(), kind: NotificationKind::Success }).await;
                            }
                            Err(e) => {
                                let _ = update_tx.send(WorkerUpdate::Notify { message: format!("Market Failed: {}", e), kind: NotificationKind::Error }).await;
                            }
                        }
                        ctx.request_repaint();
                    });
                }

                UiCommand::CheckStatus { order_id, window_ts } => {
                    tokio::spawn(async move {
                        if let Ok(res) = get_order_status(&order_id).await {
                            let matched = res["details"]["matchedSize"].as_str().unwrap_or("0").to_string();
                            let _ = update_tx.send(WorkerUpdate::OrderUpdated { window_ts, order_id, status: LocalOrderStatus::Open, matched }).await;
                        }
                        ctx.request_repaint();
                    });
                }

                UiCommand::CancelIndividual { order_id, window_ts } => {
                    tokio::spawn(async move {
                        match cancel_order(&order_id).await {
                            Ok(_) => {
                                let _ = update_tx.send(WorkerUpdate::OrderUpdated { 
                                    window_ts, 
                                    order_id: order_id.clone(), 
                                    status: LocalOrderStatus::Canceled, 
                                    matched: "0".to_string() 
                                }).await;
                                
                                // Clean order out of the polling thread array
                                {
                                    let mut lock = cmd_orders_list.lock().unwrap();
                                    lock.retain(|(_, id)| id != &order_id);
                                }
                                let _ = update_tx.send(WorkerUpdate::Notify { message: "Order Canceled".into(), kind: NotificationKind::Success }).await;
                            }
                            Err(e) => {
                                let _ = update_tx.send(WorkerUpdate::Notify { message: format!("Cancel Failed: {}", e), kind: NotificationKind::Error }).await;
                            }
                        }
                        ctx.request_repaint();
                    });
                }

                UiCommand::CancelAllInWindow { window_ts } => {
                    tokio::spawn(async move {
                        // Extract all target order IDs matching this window timestamp frame safely
                        let target_ids: Vec<String> = {
                            let lock = cmd_orders_list.lock().unwrap();
                            lock.iter()
                                .filter(|(ts, _)| *ts == window_ts)
                                .map(|(_, id)| id.clone())
                                .collect()
                        };

                        for order_id in target_ids {
                            if cancel_order(&order_id).await.is_ok() {
                                let _ = update_tx.send(WorkerUpdate::OrderUpdated { 
                                    window_ts, 
                                    order_id: order_id.clone(), 
                                    status: LocalOrderStatus::Canceled, 
                                    matched: "0".to_string() 
                                }).await;
                                
                                {
                                    let mut lock = cmd_orders_list.lock().unwrap();
                                    lock.retain(|(_, id)| id != &order_id);
                                }
                            }
                        }
                        let _ = update_tx.send(WorkerUpdate::Notify { message: "Requested Window Cancel Executed".into(), kind: NotificationKind::Info }).await;
                        ctx.request_repaint();
                    });
                }
            }
        }

        tracing::warn!("Worker command channel was dropped/closed.");
    }
}

