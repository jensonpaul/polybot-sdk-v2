// Custom Layer for sending logs to GUI
pub struct GuiLogger {
    pub tx: Sender<WorkerUpdate>,
}

struct MsgVisitor<'a> {
    msg: &'a mut String,
}

// Implement the tracing::field::Visit trait to collect the message
impl<'a> tracing::field::Visit for MsgVisitor<'a> {
    fn record_debug(&mut self, field: &tracing::field::Field, value: &dyn std::fmt::Debug) {
        use std::fmt::Write;
        let _ = write!(self.msg, "{}={:?} ", field.name(), value);
    }

    fn record_str(&mut self, field: &tracing::field::Field, value: &str) {
        use std::fmt::Write;
        let _ = write!(self.msg, "{}={} ", field.name(), value);
    }
}

impl<S: tracing::Subscriber> Layer<S> for GuiLogger {
    fn on_event(&self, event: &tracing::Event<'_>, _ctx: Context<'_, S>) {
        let level = *event.metadata().level();
        let mut msg = String::new();
        event.record(&mut MsgVisitor { msg: &mut msg });

        let tx = self.tx.clone();

        /*
        tokio::spawn(async move {
            let kind = NotificationKind::from_tracing_level(level);

            let _ = tx.send(WorkerUpdate::Notify {
                message: msg,
                kind,
            })
            .await;
        });
        */
        let kind = NotificationKind::from_tracing_level(level);
        let _ = self.tx.try_send(WorkerUpdate::Notify {
            message: msg,
            kind,
        });
    }
}

