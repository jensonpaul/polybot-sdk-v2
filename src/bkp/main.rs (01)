#[instrument(skip(payload))]
async fn place_order_limit(payload: &OrderLimitRequest) -> anyhow::Result<serde_json::Value> {
    let total_timer = Timer::start("place_order_limit_total");

    let private_key = timed!("load private key", { std::env::var("PRIVATE_KEY_VAR")? });
    let host = timed!("load host", { std::env::var("CLOB_API_URL").unwrap_or_else(|_| "https://clob.polymarket.com".into()) });
    let deposit_wallet = timed!("parse deposit wallet", { Address::from_str(&std::env::var("DEPOSIT_WALLET")?)? });

    let slug = build_slug();

    let token_ids = timed!("fetch token_ids", {
        let gamma_client = GammaClient::default();
        get_or_fetch_token_ids(&gamma_client, &slug).await?
    });
    if token_ids.len() < 2 { anyhow::bail!("No token IDs available for slug {}", slug); }

    let token_id = timed!("select token_id", {
        match payload.token.to_lowercase().as_str() {
            "up" => U256::from_str(&token_ids[0])?,
            "down" => U256::from_str(&token_ids[1])?,
            _ => anyhow::bail!("Invalid token: {}. Must be 'up' or 'down'", payload.token),
        }
    });

    let price = timed!("parse price", { Decimal::from_str(&payload.price)? });
    let size = timed!("parse size", { Decimal::from_str(&payload.size)? });
    let side = timed!("parse side", {
        match payload.side.to_lowercase().as_str() {
            "buy" => Side::Buy,
            "sell" => Side::Sell,
            _ => anyhow::bail!("Invalid side: {}", payload.side),
        }
    });

    let signer = timed!("build signer", { LocalSigner::from_str(&private_key)?.with_chain_id(Some(polybot_sdk_v2::POLYGON)) });
    let creds = timed!("get_api_creds", { get_or_fetch_api_creds(private_key.clone(), host.clone()).await? });

    let client = timed!("build & authenticate client", {
        ClobClient::new(&host, Config::default())?
            .authentication_builder(&signer)
            .funder(deposit_wallet)
            .signature_type(SignatureType::Poly1271)
            .credentials(creds)
            .authenticate()
            .await?
    });

    timed!("set tick size", { client.set_tick_size(token_id, TickSize::Hundredth); });

    let order = timed!("build order", {
        client.limit_order()
            .token_id(token_id)
            .size(size)
            .price(price)
            .side(side)
            .build()
            .await?
    });

    let signed_order = timed!("sign order", { client.sign(&signer, order).await? });
    let response = timed!("post order", { client.post_order(signed_order).await? });

    total_timer.done();
    Ok(json!({ "slug": slug, "token_id_used": token_ids[0], "response": format!("{:?}", response) }))
}

#[tokio::main]
async fn main() -> Result<()> {
    tracing_subscriber::fmt::init();

    dotenv().ok();

    let payload = OrderLimitRequest {
        token: "up".into(),
        price: "0.01".into(),
        size: "6".into(),
        side: "buy".into(),
    };

    let response = place_order_limit(&payload).await?;

    println!("Order response: {:?}", response);

    Ok(())
}
